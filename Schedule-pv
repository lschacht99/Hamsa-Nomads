<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hamsa Nomads Shavuos Retreat Schedule</title>
  <style>
    :root {
      --cream: #f7f1e6;
      --paper: #fffaf1;
      --forest: #174f19;
      --forest-dark: #0d3511;
      --sage: #dfe9dc;
      --sage-deep: #9caf92;
      --gold: #f2b544;
      --clay: #c8794a;
      --ink: #17321c;
      --muted: #6d7768;
      --line: rgba(23, 79, 25, 0.22);
      --shadow: 0 28px 70px rgba(23, 79, 25, 0.14);
      --radius-xl: 34px;
      --radius-lg: 24px;
      --max: 1180px;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at 10% 5%, rgba(242, 181, 68, 0.18), transparent 28%),
        radial-gradient(circle at 86% 18%, rgba(223, 233, 220, 0.9), transparent 32%),
        linear-gradient(135deg, #fbf4e8 0%, #f6efe4 48%, #edf4ea 100%);
      color: var(--ink);
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      opacity: 0.28;
      background-image:
        linear-gradient(rgba(23, 79, 25, 0.06) 1px, transparent 1px),
        linear-gradient(90deg, rgba(23, 79, 25, 0.05) 1px, transparent 1px);
      background-size: 44px 44px;
      mask-image: radial-gradient(circle at center, black, transparent 78%);
      z-index: 0;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .site-shell {
      position: relative;
      z-index: 1;
      min-height: 100vh;
    }

    .nav {
      position: sticky;
      top: 0;
      z-index: 50;
      backdrop-filter: blur(18px);
      background: rgba(247, 241, 230, 0.76);
      border-bottom: 1px solid rgba(23, 79, 25, 0.1);
    }

    .nav-inner {
      max-width: var(--max);
      margin: 0 auto;
      padding: 18px 22px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 800;
      letter-spacing: 0.08em;
      color: var(--forest);
      text-transform: uppercase;
      font-size: 0.86rem;
    }

    .brand-mark {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: var(--forest);
      color: var(--cream);
      font-size: 1rem;
      box-shadow: 0 10px 24px rgba(23, 79, 25, 0.2);
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.9rem;
      color: var(--forest-dark);
    }

    .nav-links a {
      padding: 10px 14px;
      border-radius: 999px;
      transition: background 0.25s ease, transform 0.25s ease;
    }

    .nav-links a:hover {
      background: rgba(23, 79, 25, 0.09);
      transform: translateY(-1px);
    }

    .cta {
      border: 1px solid rgba(23, 79, 25, 0.18);
      background: var(--forest);
      color: var(--cream) !important;
      box-shadow: 0 12px 28px rgba(23, 79, 25, 0.18);
    }

    .hero {
      position: relative;
      max-width: var(--max);
      margin: 0 auto;
      padding: 88px 22px 56px;
      display: grid;
      grid-template-columns: minmax(0, 1fr) 430px;
      gap: 54px;
      align-items: center;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      width: fit-content;
      padding: 9px 14px;
      border: 1px solid rgba(23, 79, 25, 0.16);
      border-radius: 999px;
      background: rgba(255, 250, 241, 0.7);
      color: var(--forest);
      font-size: 0.82rem;
      font-weight: 750;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      box-shadow: 0 8px 22px rgba(23, 79, 25, 0.06);
    }

    .pulse-dot {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: var(--gold);
      box-shadow: 0 0 0 0 rgba(242, 181, 68, 0.6);
      animation: pulse 2.2s infinite;
    }

    @keyframes pulse {
      0% { box-shadow: 0 0 0 0 rgba(242, 181, 68, 0.58); }
      70% { box-shadow: 0 0 0 12px rgba(242, 181, 68, 0); }
      100% { box-shadow: 0 0 0 0 rgba(242, 181, 68, 0); }
    }

    h1 {
      margin-top: 24px;
      font-family: Georgia, "Times New Roman", serif;
      color: var(--forest-dark);
      font-size: clamp(3.3rem, 8vw, 7.6rem);
      line-height: 0.9;
      letter-spacing: -0.075em;
      max-width: 820px;
    }

    .hero-lede {
      margin-top: 26px;
      max-width: 650px;
      font-size: clamp(1.04rem, 1.8vw, 1.26rem);
      line-height: 1.65;
      color: #40513f;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 34px;
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 50px;
      padding: 0 20px;
      border-radius: 999px;
      font-weight: 800;
      transition: transform 0.24s ease, box-shadow 0.24s ease, background 0.24s ease;
    }

    .button.primary {
      color: var(--cream);
      background: var(--forest);
      box-shadow: 0 14px 32px rgba(23, 79, 25, 0.2);
    }

    .button.secondary {
      color: var(--forest-dark);
      border: 1px solid rgba(23, 79, 25, 0.18);
      background: rgba(255, 250, 241, 0.64);
    }

    .button:hover {
      transform: translateY(-2px);
      box-shadow: 0 18px 38px rgba(23, 79, 25, 0.18);
    }

    .hero-card {
      position: relative;
      min-height: 560px;
      border-radius: 42px;
      background:
        linear-gradient(180deg, rgba(255, 250, 241, 0.95), rgba(223, 233, 220, 0.76)),
        radial-gradient(circle at 50% 20%, rgba(242, 181, 68, 0.25), transparent 38%);
      border: 1px solid rgba(23, 79, 25, 0.12);
      box-shadow: var(--shadow);
      overflow: hidden;
      isolation: isolate;
    }

    .hero-card::before,
    .hero-card::after {
      content: "";
      position: absolute;
      inset: 26px;
      border-radius: 34px;
      border: 1px solid rgba(23, 79, 25, 0.08);
      pointer-events: none;
    }

    .hero-card::after {
      inset: auto -30% -20% -30%;
      height: 240px;
      border: none;
      background: radial-gradient(ellipse at center, rgba(23, 79, 25, 0.13), transparent 62%);
      filter: blur(18px);
    }

    .dna-orbit {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      z-index: -1;
    }

    .dna-svg {
      width: 126%;
      height: 126%;
      opacity: 0.82;
      animation: floatDna 9s ease-in-out infinite;
    }

    @keyframes floatDna {
      0%, 100% { transform: translateY(-10px) rotate(-2deg); }
      50% { transform: translateY(12px) rotate(2deg); }
    }

    .strand-a,
    .strand-b {
      fill: none;
      stroke-width: 3.2;
      stroke-linecap: round;
      stroke-dasharray: 10 14;
      animation: strandMove 18s linear infinite;
    }

    .strand-a { stroke: rgba(23, 79, 25, 0.42); }
    .strand-b { stroke: rgba(242, 181, 68, 0.74); animation-direction: reverse; }

    .rung {
      stroke: rgba(23, 79, 25, 0.18);
      stroke-width: 2;
      stroke-linecap: round;
      animation: rungFade 3.6s ease-in-out infinite;
    }

    .rung:nth-of-type(2n) { animation-delay: 0.35s; }
    .rung:nth-of-type(3n) { animation-delay: 0.75s; }

    @keyframes strandMove {
      to { stroke-dashoffset: -240; }
    }

    @keyframes rungFade {
      0%, 100% { opacity: 0.22; transform: scaleX(0.88); }
      50% { opacity: 0.78; transform: scaleX(1); }
    }

    .hero-card-content {
      position: absolute;
      inset: auto 26px 26px 26px;
      padding: 28px;
      border-radius: 30px;
      background: rgba(255, 250, 241, 0.78);
      backdrop-filter: blur(18px);
      border: 1px solid rgba(23, 79, 25, 0.12);
      box-shadow: 0 20px 48px rgba(23, 79, 25, 0.12);
    }

    .card-kicker {
      font-size: 0.78rem;
      font-weight: 900;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--clay);
    }

    .hero-card h2 {
      margin-top: 10px;
      color: var(--forest-dark);
      font-family: Georgia, "Times New Roman", serif;
      font-size: 2.25rem;
      letter-spacing: -0.04em;
      line-height: 1;
    }

    .mini-meta {
      margin-top: 18px;
      display: grid;
      gap: 10px;
      color: #425344;
      font-weight: 650;
    }

    .mini-meta span {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .mini-meta i {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: var(--gold);
      flex: 0 0 auto;
    }

    section {
      position: relative;
      max-width: var(--max);
      margin: 0 auto;
      padding: 72px 22px;
    }

    .section-heading {
      display: grid;
      grid-template-columns: minmax(0, 0.8fr) minmax(0, 1fr);
      gap: 30px;
      align-items: end;
      margin-bottom: 38px;
    }

    .section-heading h2 {
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(2.25rem, 4vw, 4.6rem);
      line-height: 0.96;
      letter-spacing: -0.055em;
      color: var(--forest-dark);
    }

    .section-heading p {
      font-size: 1.05rem;
      line-height: 1.65;
      color: #526052;
      max-width: 620px;
    }

    .schedule-wrap {
      position: relative;
      padding: 20px 0 0;
    }

    .dna-timeline {
      position: absolute;
      left: 50%;
      top: 0;
      bottom: 0;
      width: 96px;
      transform: translateX(-50%);
      pointer-events: none;
      opacity: 0.88;
    }

    .timeline-svg {
      position: sticky;
      top: 88px;
      width: 96px;
      height: calc(100vh - 120px);
      min-height: 640px;
      overflow: visible;
    }

    .timeline-path {
      fill: none;
      stroke: rgba(23, 79, 25, 0.25);
      stroke-width: 2;
      stroke-dasharray: 8 12;
      animation: strandMove 16s linear infinite;
    }

    .timeline-path.gold {
      stroke: rgba(242, 181, 68, 0.8);
      animation-direction: reverse;
    }

    .schedule-day {
      position: relative;
      display: grid;
      grid-template-columns: minmax(0, 1fr) 120px minmax(0, 1fr);
      gap: 22px;
      min-height: 190px;
      margin-bottom: 26px;
    }

    .schedule-day:nth-child(even) .day-card {
      grid-column: 3;
    }

    .schedule-day:nth-child(odd) .day-card {
      grid-column: 1;
    }

    .day-marker {
      grid-column: 2;
      align-self: start;
      justify-self: center;
      position: sticky;
      top: 166px;
      width: 76px;
      height: 76px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      color: var(--cream);
      background: var(--forest);
      border: 5px solid var(--cream);
      box-shadow: 0 18px 42px rgba(23, 79, 25, 0.25);
      z-index: 4;
    }

    .day-marker::after {
      content: "";
      position: absolute;
      inset: -11px;
      border-radius: 50%;
      border: 1px solid rgba(242, 181, 68, 0.7);
      animation: markerRing 3.4s ease-in-out infinite;
    }

    @keyframes markerRing {
      0%, 100% { transform: scale(0.92); opacity: 0.2; }
      50% { transform: scale(1.08); opacity: 0.72; }
    }

    .day-marker strong {
      font-family: Georgia, "Times New Roman", serif;
      font-size: 1.65rem;
      line-height: 1;
    }

    .day-card {
      position: relative;
      border-radius: var(--radius-xl);
      background: rgba(255, 250, 241, 0.76);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(23, 79, 25, 0.13);
      box-shadow: 0 20px 50px rgba(23, 79, 25, 0.1);
      overflow: hidden;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .day-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 28px 70px rgba(23, 79, 25, 0.16);
    }

    .day-card::before {
      content: "";
      position: absolute;
      inset: 0 0 auto 0;
      height: 8px;
      background:
        radial-gradient(circle at 12px 50%, rgba(242, 181, 68, 0.72) 0 3px, transparent 4px),
        linear-gradient(90deg, rgba(23, 79, 25, 0.16), rgba(23, 79, 25, 0.34), rgba(242, 181, 68, 0.48), rgba(23, 79, 25, 0.26));
      background-size: 34px 8px, 100% 8px;
      opacity: 0.9;
      animation: dnaCardAccent 12s linear infinite;
    }

    @keyframes dnaCardAccent {
      to { background-position: 34px 0, 0 0; }
    }

    .day-card-inner {
      padding: 30px;
    }

    .day-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 18px;
      margin-bottom: 20px;
    }

    .day-label {
      font-size: 0.78rem;
      font-weight: 900;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--clay);
    }

    .day-title {
      margin-top: 7px;
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(1.85rem, 3.3vw, 3.1rem);
      line-height: 0.98;
      letter-spacing: -0.045em;
      color: var(--forest-dark);
    }

    .day-date {
      white-space: nowrap;
      padding: 9px 12px;
      border-radius: 999px;
      background: rgba(223, 233, 220, 0.74);
      border: 1px solid rgba(23, 79, 25, 0.12);
      color: var(--forest);
      font-size: 0.82rem;
      font-weight: 850;
    }

    .events {
      display: grid;
      gap: 12px;
    }

    .event {
      display: grid;
      grid-template-columns: 98px minmax(0, 1fr);
      gap: 18px;
      padding: 14px 0;
      border-top: 1px solid rgba(23, 79, 25, 0.1);
    }

    .event-time {
      color: var(--forest);
      font-size: 0.82rem;
      font-weight: 900;
      letter-spacing: 0.02em;
      padding-top: 2px;
    }

    .event-title {
      font-weight: 900;
      color: #203b24;
      line-height: 1.25;
    }

    .event-desc {
      margin-top: 5px;
      color: #5a6758;
      line-height: 1.55;
      font-size: 0.95rem;
    }

    .tag-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 22px;
    }

    .tag {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 11px;
      border-radius: 999px;
      background: rgba(247, 241, 230, 0.86);
      border: 1px solid rgba(23, 79, 25, 0.13);
      color: var(--forest-dark);
      font-size: 0.78rem;
      font-weight: 800;
    }

    .tag::before {
      content: "";
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--gold);
    }

    .feature-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 18px;
    }

    .feature-card {
      position: relative;
      padding: 28px;
      min-height: 260px;
      border-radius: var(--radius-xl);
      background: rgba(255, 250, 241, 0.72);
      border: 1px solid rgba(23, 79, 25, 0.12);
      box-shadow: 0 20px 50px rgba(23, 79, 25, 0.1);
      overflow: hidden;
      isolation: isolate;
    }

    .feature-card::before {
      content: "";
      position: absolute;
      width: 180px;
      height: 180px;
      right: -70px;
      top: -70px;
      border-radius: 50%;
      background: rgba(242, 181, 68, 0.16);
      z-index: -1;
      animation: softSpin 12s linear infinite;
    }

    @keyframes softSpin {
      to { transform: rotate(360deg); }
    }

    .feature-number {
      width: 48px;
      height: 48px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      background: var(--forest);
      color: var(--cream);
      font-family: Georgia, "Times New Roman", serif;
      font-weight: 900;
      font-size: 1.35rem;
      margin-bottom: 22px;
    }

    .feature-card h3 {
      font-family: Georgia, "Times New Roman", serif;
      font-size: 1.8rem;
      line-height: 1;
      letter-spacing: -0.04em;
      color: var(--forest-dark);
    }

    .feature-card p {
      margin-top: 14px;
      color: #576653;
      line-height: 1.62;
    }

    .closing {
      max-width: var(--max);
      margin: 28px auto 86px;
      padding: 0 22px;
    }

    .closing-card {
      position: relative;
      border-radius: 44px;
      padding: clamp(34px, 6vw, 70px);
      background:
        linear-gradient(135deg, rgba(23, 79, 25, 0.95), rgba(13, 53, 17, 0.92)),
        radial-gradient(circle at 10% 10%, rgba(242, 181, 68, 0.38), transparent 34%);
      color: var(--cream);
      overflow: hidden;
      box-shadow: 0 32px 86px rgba(23, 79, 25, 0.24);
    }

    .closing-card::before {
      content: "";
      position: absolute;
      inset: -40% -20%;
      background:
        repeating-linear-gradient(120deg, rgba(255, 250, 241, 0.08) 0 1px, transparent 1px 26px);
      animation: slideTexture 18s linear infinite;
      pointer-events: none;
    }

    @keyframes slideTexture {
      to { transform: translateX(120px); }
    }

    .closing-content {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 26px;
      align-items: end;
    }

    .closing h2 {
      max-width: 820px;
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(2.5rem, 6vw, 6rem);
      line-height: 0.94;
      letter-spacing: -0.065em;
    }

    .closing p {
      margin-top: 20px;
      max-width: 620px;
      color: rgba(255, 250, 241, 0.78);
      font-size: 1.08rem;
      line-height: 1.65;
    }

    .closing .button {
      background: var(--gold);
      color: var(--forest-dark);
      box-shadow: 0 18px 38px rgba(0, 0, 0, 0.18);
    }

    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.75s ease, transform 0.75s ease;
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    @media (max-width: 980px) {
      .hero {
        grid-template-columns: 1fr;
        padding-top: 58px;
      }

      .hero-card {
        min-height: 520px;
      }

      .section-heading,
      .closing-content {
        grid-template-columns: 1fr;
      }

      .feature-grid {
        grid-template-columns: 1fr;
      }

      .schedule-day,
      .schedule-day:nth-child(even),
      .schedule-day:nth-child(odd) {
        grid-template-columns: 74px minmax(0, 1fr);
        gap: 14px;
      }

      .schedule-day:nth-child(even) .day-card,
      .schedule-day:nth-child(odd) .day-card {
        grid-column: 2;
      }

      .day-marker {
        grid-column: 1;
        width: 58px;
        height: 58px;
        top: 128px;
      }

      .day-marker strong {
        font-size: 1.24rem;
      }

      .dna-timeline {
        left: 36px;
        width: 70px;
      }

      .timeline-svg {
        width: 70px;
      }
    }

    @media (max-width: 680px) {
      .nav-inner {
        align-items: flex-start;
      }

      .nav-links a:not(.cta) {
        display: none;
      }

      .hero {
        padding: 42px 18px 42px;
        gap: 32px;
      }

      .hero-card {
        min-height: 470px;
        border-radius: 32px;
      }

      .hero-card-content {
        inset: auto 16px 16px 16px;
        padding: 22px;
        border-radius: 24px;
      }

      section {
        padding: 56px 18px;
      }

      .schedule-day,
      .schedule-day:nth-child(even),
      .schedule-day:nth-child(odd) {
        grid-template-columns: 1fr;
        margin-bottom: 18px;
      }

      .dna-timeline,
      .day-marker {
        display: none;
      }

      .schedule-day:nth-child(even) .day-card,
      .schedule-day:nth-child(odd) .day-card {
        grid-column: 1;
      }

      .day-card-inner {
        padding: 24px;
      }

      .day-top {
        flex-direction: column;
      }

      .event {
        grid-template-columns: 1fr;
        gap: 6px;
      }

      .closing {
        margin-bottom: 48px;
        padding: 0 18px;
      }
    }
  </style>
</head>
<body>
  <div class="site-shell">
    <header class="nav">
      <div class="nav-inner">
        <a class="brand" href="#top" aria-label="Hamsa Nomads home">
          <span class="brand-mark">✦</span>
          <span>Hamsa Nomads</span>
        </a>
        <nav class="nav-links" aria-label="Schedule navigation">
          <a href="#schedule">Schedule</a>
          <a href="#highlights">Highlights</a>
          <a class="cta" href="https://hamsanomads.com">Apply Now</a>
        </nav>
      </div>
    </header>

    <main id="top">
      <section class="hero" aria-labelledby="page-title">
        <div class="hero-copy reveal">
          <div class="eyebrow"><span class="pulse-dot"></span> Shavuos in the Vermont mountains</div>
