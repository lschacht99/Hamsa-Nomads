<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hamsa Nomads — The Birch Villa Retreat</title>
  <style>
    :root {
      --bg: #f6f0e7;
      --bg-2: #f9f6f1;
      --paper: #fbf8f3;
      --ink: #171514;
      --muted: #6f665e;
      --line: rgba(10, 10, 10, 0.95);
      --card: rgba(255, 255, 255, 0.56);
      --border: rgba(23, 21, 20, 0.1);
      --accent: #1d4736;
      --shadow: 0 18px 50px rgba(28, 20, 13, 0.08);
      --radius: 26px;
      --container: 1180px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      position: relative;
      z-index: 1; /* ensure all content sits above line */
      margin: 0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at top left, rgba(255,255,255,0.75), transparent 30%),
        linear-gradient(180deg, var(--bg-2) 0%, var(--bg) 100%);
      line-height: 1.55;
      overflow-x: hidden;
    }

    h1, h2, h3, h4, .serif {
      font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Palatino, Georgia, serif;
      font-weight: 500;
      letter-spacing: -0.025em;
    }

    a { color: inherit; text-decoration: none; }
    img { max-width: 100%; display: block; }

    .line-overlay {
      position: fixed;
      inset: 0;
      z-index: 0; /* true background */
      pointer-events: none;
      overflow: hidden;
    }

    .line-overlay svg {
      width: 100%;
      height: 100%;
      overflow: visible;
    }

    .path-main,
    .path-slice {
      fill: none;
      stroke: var(--line);
      stroke-linecap: round;
      stroke-linejoin: round;
      vector-effect: non-scaling-stroke;
    }

    .path-main.back { stroke-width: 2.8; opacity: 0.96; }
    .path-main.front { stroke-width: 1.35; opacity: 0.98; }
    .path-slice.back { stroke-width: 2.5; opacity: 0.95; }
    .path-slice.front { stroke-width: 1.2; opacity: 0.98; }

    .container {
      position: relative;
      z-index: 5;
      width: min(calc(100% - 32px), var(--container));
      margin: 0 auto;
      position: relative;
      z-index: 10; /* above line */
    }

    .line-safe {
      position: relative;
      z-index: 15; /* above line */
      background: var(--paper);
      border-radius: 24px;
      padding: 8px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .site-header {
      position: sticky;
      top: 0;
      z-index: 50; /* clearly above background */
      position: sticky;
      top: 0;
      z-index: 20; /* above line */
      backdrop-filter: blur(12px);
      background: rgba(246, 240, 231, 0.78);
      border-bottom: 1px solid rgba(23,21,20,0.06);
    }

    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      min-height: 72px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 0.96rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .brand-mark {
      width: 34px;
      height: 34px;
      border-radius: 999px;
      border: 1px solid rgba(23,21,20,0.15);
      display: grid;
      place-items: center;
      background: rgba(255,255,255,0.55);
      box-shadow: 0 6px 20px rgba(0,0,0,0.03);
      font-size: 0.9rem;
    }

    .nav-links {
      display: flex;
      gap: 20px;
      color: var(--muted);
      font-size: 0.95rem;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .nav-links a:hover { color: var(--ink); }

    section {
      padding: 22px 0 28px;
      position: relative;
    }

    .hero {
      padding: 64px 0 34px;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 30px;
      align-items: end;
    }

    .eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.77rem;
      color: var(--muted);
      margin-bottom: 18px;
    }

    .hero h1 {
      font-size: clamp(2.9rem, 7vw, 6rem);
      line-height: 0.94;
      margin: 0 0 18px;
      max-width: 9ch;
    }

    .hero p.lead {
      font-size: 1.07rem;
      max-width: 60ch;
      color: rgba(23,21,20,0.82);
      margin: 0 0 22px;
    }

    .pill-row,
    .specs {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .pill,
    .spec {
      border: 1px solid var(--border);
      padding: 10px 14px;
      border-radius: 999px;
      font-size: 0.91rem;
      background: rgba(255,255,255,0.44);
      box-shadow: 0 6px 18px rgba(0,0,0,0.03);
    }

    .hero-card,
    .section-card,
    .info-card,
    .gallery-card,
    .amenity-card,
    .detail-card,
    .faq-card,
    .footer-card,
    .cta-panel {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      backdrop-filter: blur(6px);
    }

    .hero-card { 
      padding: 14px;
      position: relative;
    }

    .hero-image {
      width: 100%;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      border-radius: 20px;
    }

    .hero-caption {
      padding: 14px 8px 4px;
      color: rgba(23,21,20,0.78);
      font-size: 0.95rem;
      max-width: 54ch;
    }

    .hero-cta {
      position: absolute;
      bottom: 18px;
      left: 18px;
      z-index: 5;
    }

    .hero-cta .button {
      box-shadow: 0 10px 30px rgba(0,0,0,0.18);
      backdrop-filter: blur(6px);
    }

    .section-header {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 20px;
      margin-bottom: 18px;
    }

    .section-header h2 {
      font-size: clamp(2rem, 4vw, 3.2rem);
      line-height: 1;
      margin: 0;
    }

    .section-header p {
      color: var(--muted);
      max-width: 56ch;
      margin: 0;
    }

    .info-grid,
    .gallery-grid,
    .amenity-grid,
    .detail-grid,
    .faq-grid,
    .footer-grid {
      display: grid;
      gap: 18px;
    }

    .info-grid { grid-template-columns: repeat(4, 1fr); }
    .gallery-grid { grid-template-columns: 1.2fr 0.8fr 0.8fr; }
    .amenity-grid { grid-template-columns: repeat(3, 1fr); }
    .detail-grid { grid-template-columns: 1.05fr 0.95fr; align-items: start; }
    .faq-grid { grid-template-columns: repeat(2, 1fr); }
    .footer-grid { grid-template-columns: 1.15fr 0.85fr; }

    .info-card,
    .gallery-card,
    .amenity-card,
    .detail-card,
    .faq-card,
    .footer-card {
      padding: 18px;
      position: relative;
      overflow: hidden;
    }

    .meta-label {
      font-size: 0.78rem;
      letter-spacing: 0.1em;
      color: var(--muted);
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .meta-value {
      font-size: 1.05rem;
      line-height: 1.38;
    }

    .gallery-card {
      padding: 10px;
    }

    .gallery-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 18px;
      min-height: 240px;
    }

    .gallery-card.tall { grid-row: span 2; }

    h3 {
      margin: 0 0 10px;
      font-size: 1.35rem;
    }

    p,
    li {
      color: rgba(23,21,20,0.78);
    }

    ul.clean {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 12px;
    }

    ul.clean li {
      padding-left: 16px;
      position: relative;
    }

    ul.clean li::before {
      content: "•";
      position: absolute;
      left: 0;
      top: 0;
      color: var(--accent);
    }

    .schedule-list {
      display: grid;
      gap: 14px;
    }

    .schedule-item {
      display: grid;
      grid-template-columns: 116px 1fr;
      gap: 14px;
      padding: 14px 0;
      border-bottom: 1px solid rgba(23,21,20,0.08);
    }

    .schedule-item:last-child { border-bottom: 0; }
    .schedule-day {
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 0.8rem;
      padding-top: 4px;
    }

    .cta-panel {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 18px;
      padding: 22px 24px;
    }

    .button-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 46px;
      padding: 0 22px;
      border-radius: 999px;
      border: 1px solid var(--ink);
      background: var(--ink);
      color: #fff;
      font-size: 0.95rem;
      font-weight: 600;
      letter-spacing: 0.02em;
    }

    .button.secondary {
      background: transparent;
      color: var(--ink);
      border-color: rgba(23,21,20,0.14);
    }

    .small { font-size: 0.93rem; }
    .muted { color: var(--muted); }

    footer { padding: 14px 0 60px; }
    .footer-note { margin-top: 16px; color: var(--muted); font-size: 0.9rem; }

    @media (max-width: 1080px) {
      .hero-grid,
      .gallery-grid,
      .detail-grid,
      .footer-grid,
      .info-grid,
      .amenity-grid,
      .faq-grid {
        grid-template-columns: 1fr 1fr;
      }

      .hero-grid > :first-child,
      .detail-grid > :first-child,
      .footer-grid > :first-child,
      .gallery-grid > :first-child {
        grid-column: 1 / -1;
      }

      .gallery-card.tall { grid-row: span 1; }
    }

    @media (max-width: 760px) {
      .nav {
        align-items: start;
        flex-direction: column;
        padding: 14px 0;
      }

      .nav-links { gap: 12px 14px; }
      .hero { padding-top: 34px; }

      .hero-grid,
      .gallery-grid,
      .detail-grid,
      .footer-grid,
      .info-grid,
      .amenity-grid,
      .faq-grid,
      .cta-panel {
        grid-template-columns: 1fr;
      }

      .schedule-item {
        grid-template-columns: 1fr;
        gap: 8px;
      }

      .section-header {
        align-items: start;
        flex-direction: column;
      }

      .hero h1 { max-width: 12ch; }
      .gallery-card img { min-height: 220px; }
    }
  </style>
</head>
