  <header class="site-header">
    <div class="container nav">
      <a href="#top" class="brand">
        <span class="brand-mark">⌂</span>
        <span>Hamsa Nomads</span>
      </a>
      <nav class="nav-links">
        <a href="#stay">Stay</a>
        <a href="#gallery">Gallery</a>
