<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hamsa Nomads — Shavuos in Vermont</title>
  <link rel="icon" href="/favicon.ico?v=5" type="image/x-icon">
  <link rel="shortcut icon" href="/favicon.ico?v=5" type="image/x-icon">
  <link rel="stylesheet" href="assets/site-components.css" />

  <style>
    :root {
      --bg: #f7f3ea;
      --paper: rgba(255, 252, 246, 0.68);
      --paper-strong: rgba(255, 252, 246, 0.86);
      --ink: #1f231f;
      --muted: #60655e;
      --forest: #274537;
      --forest-dark: #173c30;
      --gold: #b88b2f;
      --line: rgba(16, 14, 11, 0.18);
      --shadow: 0 20px 70px rgba(31, 28, 20, 0.10);
      --soft-shadow: 0 14px 38px rgba(31, 28, 20, 0.08);
      --radius: 28px;
      --container: 1280px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      font-family: Inter, Arial, sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at top left, rgba(255,255,255,0.82), transparent 34%),
        radial-gradient(circle at 88% 12%, rgba(184,139,47,0.10), transparent 28%),
        linear-gradient(180deg, #faf7f0 0%, var(--bg) 100%);
      line-height: 1.65;
      overflow-x: hidden;
    }

    h1, h2, h3, h4, .serif {
      font-family: "Iowan Old Style", "Palatino Linotype", Georgia, serif;
      font-weight: 500;
      letter-spacing: -0.035em;
      margin: 0;
    }

    p { margin: 0; }
    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }

    #site-header { position: sticky; top: 0; z-index: 99999; }
    .hn-shared-header { position: relative; top: auto; z-index: 99999; }
    #site-footer { position: relative; z-index: 2; }

    .site-shell {
      position: relative;
      isolation: isolate;
      min-height: 100vh;
      overflow: hidden;
    }

    .container {
      width: min(calc(100% - 32px), var(--container));
      margin: 0 auto;
      position: relative;
      z-index: 2;
    }

    .glass {
      background: var(--paper);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255,255,255,0.52);
      box-shadow: var(--soft-shadow), inset 0 1px 0 rgba(255,255,255,0.46);
      border-radius: var(--radius);
    }

    .button,
    .button-secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 52px;
      padding: 0 26px;
      border-radius: 999px;
      font-size: 0.96rem;
      font-weight: 800;
      letter-spacing: 0.02em;
      transition: transform 0.22s ease, box-shadow 0.22s ease, opacity 0.22s ease;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .button:hover,
    .button-secondary:hover { transform: translateY(-2px); }

    .button {
      background: rgba(39, 69, 55, 0.94);
      color: white;
      box-shadow: 0 14px 34px rgba(39, 69, 55, 0.24);
      border: 1px solid rgba(39, 69, 55, 0.26);
    }

    .button-secondary {
      background: rgba(255,255,255,0.70);
      color: var(--ink);
      border: 1px solid rgba(39, 69, 55, 0.14);
      box-shadow: 0 10px 24px rgba(31, 28, 20, 0.08);
    }

    .eyebrow {
      font-size: 0.78rem;
      letter-spacing: 0.17em;
      text-transform: uppercase;
      color: var(--gold);
      font-weight: 900;
      margin-bottom: 14px;
    }

    .section {
      position: relative;
      padding: clamp(42px, 7vw, 92px) 0;
    }

    .section-intro {
      max-width: 790px;
      margin-bottom: 34px;
    }

    .section-intro.center {
      margin-inline: auto;
      text-align: center;
    }

    .section-intro h2 {
      font-size: clamp(2.25rem, 5.5vw, 4.65rem);
      line-height: 0.98;
      color: var(--forest);
    }

    .section-intro p {
      margin-top: 18px;
      color: var(--muted);
      font-size: clamp(1rem, 1.4vw, 1.13rem);
      line-height: 1.75;
    }

    [data-reveal] {
      opacity: 0;
      transform: translateY(26px);
      transition: opacity 0.75s cubic-bezier(.2,.7,.2,1), transform 0.75s cubic-bezier(.2,.7,.2,1);
      transition-delay: var(--delay, 0ms);
    }

    [data-reveal].is-visible { opacity: 1; transform: translateY(0); }

    [data-float] {
      animation: softFloat 7s ease-in-out infinite;
      animation-delay: var(--float-delay, 0s);
    }

    @keyframes softFloat {
      0%, 100% { transform: translate3d(0, 0, 0) rotate(var(--rotate, 0deg)); }
      50% { transform: translate3d(0, -12px, 0) rotate(var(--rotate, 0deg)); }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { animation: none !important; scroll-behavior: auto !important; transition: none !important; }
      [data-reveal] { opacity: 1 !important; transform: none !important; }
    }

    .hero { padding: 24px 0 34px; }

    .hero-card {
      position: relative;
      min-height: min(830px, 86vh);
      overflow: hidden;
      border-radius: 38px;
      background: #e9dfd0;
      box-shadow: var(--shadow);
      display: grid;
      align-items: stretch;
    }

    .hero-media {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: saturate(0.98);
    }

    .hero-scrim {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(90deg, rgba(20, 18, 12, 0.64), rgba(20, 18, 12, 0.26) 54%, rgba(20, 18, 12, 0.07)),
        linear-gradient(180deg, rgba(20,18,12,0.07), rgba(20,18,12,0.40));
    }

    .hero-content {
      position: relative;
      z-index: 3;
      min-height: inherit;
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(320px, 0.76fr);
      gap: clamp(24px, 4vw, 46px);
      align-items: end;
      padding: clamp(26px, 5vw, 64px);
    }

    .hero-copy {
      color: #fffdf8;
      max-width: 760px;
      align-self: center;
    }

    .hero .eyebrow { color: #e0ae43; text-shadow: 0 4px 16px rgba(0,0,0,0.25); }

    .hero h1 {
      font-size: clamp(3.2rem, 7.8vw, 7rem);
      line-height: 0.9;
      color: #fffdf8;
      max-width: 9.5ch;
      margin-bottom: 20px;
      text-shadow: 0 10px 32px rgba(0,0,0,0.25);
    }

    .hero h1 span { color: #e0ae43; }

    .hero-lead {
      max-width: 43ch;
      font-size: clamp(1.08rem, 2vw, 1.34rem);
      line-height: 1.48;
      color: rgba(255,251,245,0.94);
      margin-bottom: 24px;
      text-shadow: 0 6px 20px rgba(0,0,0,0.24);
    }

    .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 22px; }

    .hero-countdown {
      width: min(650px, 100%);
      padding-top: 18px;
      border-top: 1px solid rgba(255, 255, 255, 0.24);
    }

    .countdown-header {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 14px;
      color: rgba(255, 253, 248, 0.9);
      font-size: 0.78rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      text-shadow: 0 5px 18px rgba(0, 0, 0, 0.22);
      flex-wrap: wrap;
    }

    .countdown-header strong { color: #e0ae43; font-weight: 900; }
    .countdown-row { display: flex; align-items: flex-start; gap: clamp(10px, 2vw, 28px); }
    .countdown-unit { text-align: center; min-width: 54px; }

    .countdown-number {
      font-family: Inter, Arial, sans-serif;
      font-size: clamp(2rem, 5vw, 3.35rem);
      font-weight: 900;
      color: #e0ae43;
      line-height: 1;
      letter-spacing: -0.045em;
      text-shadow: 0 8px 26px rgba(0, 0, 0, 0.28);
    }

    .countdown-label {
      margin-top: 8px;
      color: rgba(224, 174, 67, 0.55);
      font-size: 0.52rem;
      font-weight: 900;
      letter-spacing: 0.26em;
      text-transform: uppercase;
    }

    .countdown-separator {
      padding-top: 3px;
      color: rgba(224, 174, 67, 0.28);
      font-size: clamp(1.6rem, 3vw, 2.15rem);
      font-weight: 900;
      line-height: 1;
    }

    .countdown-note {
      margin-top: 14px;
      color: rgba(255, 251, 245, 0.78);
      font-size: 0.92rem;
      text-shadow: 0 5px 18px rgba(0, 0, 0, 0.18);
    }

    .hero-vibe-stack { position: relative; min-height: 480px; align-self: center; }

    .vibe-polaroid,
    .ambient-post,
    .margin-post {
      border-radius: 24px;
      overflow: hidden;
      background: rgba(255, 252, 246, 0.88);
      padding: 9px;
      box-shadow: 0 20px 50px rgba(0,0,0,0.20);
      border: 1px solid rgba(255,255,255,0.55);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      transform: rotate(var(--rotate, 0deg));
    }

    .vibe-polaroid { position: absolute; width: clamp(150px, 16vw, 230px); }

    .vibe-polaroid img,
    .vibe-polaroid .vibe-placeholder,
    .ambient-post img,
    .ambient-post .vibe-placeholder,
    .margin-post img,
    .margin-post .vibe-placeholder {
      width: 100%;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      border-radius: 17px;
      background: radial-gradient(circle at top left, rgba(244,231,199,0.8), transparent 34%), linear-gradient(145deg, #f4e7c7, #d9c69b);
    }

    .vibe-polaroid span,
    .ambient-post span,
    .margin-post span {
      display: block;
      padding: 8px 5px 2px;
      font-size: 0.70rem;
      color: var(--forest);
      font-weight: 900;
      letter-spacing: 0.09em;
      text-transform: uppercase;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .vibe-polaroid.one { top: 7%; left: 0; --rotate: -8deg; --float-delay: -1s; }
    .vibe-polaroid.two { top: 33%; right: 2%; --rotate: 8deg; --float-delay: -3s; }
    .vibe-polaroid.three { bottom: 0; left: 18%; --rotate: -3deg; --float-delay: -5s; }

    .hero-fact-pill {
      position: absolute;
      z-index: 5;
      display: inline-flex;
      align-items: center;
      gap: 9px;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(255, 252, 246, 0.88);
      color: var(--forest);
      font-size: 0.76rem;
      font-weight: 900;
      letter-spacing: 0.10em;
      text-transform: uppercase;
      box-shadow: 0 16px 34px rgba(0,0,0,0.13);
      border: 1px solid rgba(255,255,255,0.52);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }

    .hero-fact-pill::before {
      content: "";
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: #d7b05b;
      box-shadow: 0 0 0 5px rgba(215,176,91,0.18);
    }

    .pill-one { right: 5%; top: 5%; }
    .pill-two { right: 18%; bottom: 8%; }
    .pill-three { left: 5%; bottom: 5%; }

    .manifesto { padding-top: clamp(40px, 6vw, 78px); padding-bottom: clamp(34px, 5vw, 62px); }

    .manifesto-grid {
      display: grid;
      grid-template-columns: 0.95fr 1.05fr;
      gap: clamp(24px, 5vw, 64px);
      align-items: center;
    }

    .manifesto-statement h2 {
      font-size: clamp(2.5rem, 6vw, 5.2rem);
      color: var(--forest);
      line-height: 0.96;
    }

    .manifesto-statement p {
      margin-top: 20px;
      color: var(--muted);
      max-width: 46ch;
      font-size: 1.08rem;
    }

    .proof-cloud { position: relative; min-height: 430px; }

    .proof-note {
      position: absolute;
      padding: 22px;
      border-radius: 28px;
      background: rgba(255,252,246,0.72);
      border: 1px solid rgba(255,255,255,0.55);
      box-shadow: var(--soft-shadow);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      width: min(320px, 72vw);
    }

    .proof-note h3 { color: var(--forest); font-size: 1.55rem; margin-bottom: 8px; }
    .proof-note p { color: var(--muted); line-height: 1.62; }
    .proof-note.a { left: 0; top: 28px; --rotate: -2deg; }
    .proof-note.b { right: 8%; top: 130px; --rotate: 3deg; }
    .proof-note.c { left: 16%; bottom: 12px; --rotate: -1deg; }

    .timeline-wrap {
      display: grid;
      grid-template-columns: minmax(240px, 0.54fr) minmax(0, 1fr);
      gap: clamp(28px, 5vw, 68px);
      align-items: start;
    }

    .timeline-sticky { position: sticky; top: 112px; align-self: start; }
    .timeline-sticky h2 { font-size: clamp(2.3rem, 5vw, 4.65rem); line-height: 0.96; color: var(--forest); }
    .timeline-sticky p { margin-top: 18px; color: var(--muted); max-width: 34ch; }

    .timeline {
      position: relative;
      padding-left: clamp(18px, 3vw, 38px);
      border-left: 1px solid rgba(39,69,55,0.16);
    }

    .timeline::before {
      content: "";
      position: absolute;
      top: 0;
      left: -5px;
      width: 9px;
      height: 9px;
      border-radius: 999px;
      background: var(--gold);
      box-shadow: 0 0 0 7px rgba(184,139,47,0.12);
    }

    .timeline-item { position: relative; margin-bottom: clamp(32px, 5vw, 62px); max-width: 760px; }

    .timeline-time {
      display: inline-flex;
      margin-bottom: 10px;
      padding: 7px 11px;
      border-radius: 999px;
      background: rgba(39,69,55,0.08);
      color: var(--forest);
      font-size: 0.72rem;
      font-weight: 900;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .timeline-item h3 { font-size: clamp(1.65rem, 3.2vw, 2.55rem); color: var(--ink); margin-bottom: 12px; }
    .timeline-item p { color: var(--muted); font-size: 1.03rem; line-height: 1.82; }

    .margin-post {
      position: relative;
      float: right;
      width: min(250px, 44vw);
      margin: 6px -14px 16px 24px;
      transform: rotate(3deg);
    }

    .margin-post img,
    .margin-post .vibe-placeholder { aspect-ratio: 1 / 1; }

    .house-bento {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr 0.85fr;
      grid-auto-rows: minmax(220px, auto);
      gap: 16px;
    }

    .house-card {
      position: relative;
      border-radius: 30px;
      overflow: hidden;
      min-height: 260px;
      box-shadow: var(--soft-shadow);
      background: #e9dfd0;
      border: 1px solid rgba(255,255,255,0.52);
    }

    .house-card.large { grid-row: span 2; min-height: 520px; }

    .house-card img {
      width: 100%;
      height: 100%;
      min-height: inherit;
      object-fit: cover;
      transition: transform 0.45s ease, filter 0.45s ease;
    }

    .house-card:hover img { transform: scale(1.045); filter: brightness(0.86); }

    .house-label {
      position: absolute;
      left: 16px;
      bottom: 16px;
      z-index: 2;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(255,255,255,0.18);
      border: 1px solid rgba(255,255,255,0.30);
      color: #fff;
      backdrop-filter: blur(14px) saturate(160%);
      -webkit-backdrop-filter: blur(14px) saturate(160%);
      font-size: 0.88rem;
      font-weight: 800;
      box-shadow: 0 8px 24px rgba(0,0,0,0.16);
      white-space: nowrap;
    }

    .apply-panel {
      position: relative;
      overflow: hidden;
      padding: clamp(26px, 5vw, 48px);
      border-radius: 42px;
      background:
        radial-gradient(circle at top left, rgba(242, 181, 68, 0.18), transparent 38%),
        radial-gradient(circle at bottom right, rgba(39,69,55,0.09), transparent 34%),
        rgba(255, 252, 246, 0.72);
      border: 1px solid rgba(255,255,255,0.55);
      box-shadow: var(--shadow);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      display: grid;
      grid-template-columns: 1.22fr 0.78fr;
      gap: clamp(22px, 4vw, 44px);
      align-items: center;
    }

    .price-main h2 {
      color: var(--forest);
      font-size: clamp(2.4rem, 6vw, 5rem);
      line-height: 0.94;
      max-width: 740px;
    }

    .price-main p { margin-top: 16px; color: var(--muted); font-size: 1.07rem; max-width: 58ch; }

    .price-side {
      padding: 22px;
      border-radius: 30px;
      background: rgba(255,255,255,0.45);
      border: 1px solid rgba(255,255,255,0.45);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.35);
    }

    .price-number {
      font-family: "Iowan Old Style", "Palatino Linotype", Georgia, serif;
      font-size: clamp(3.5rem, 8vw, 5.8rem);
      line-height: 0.88;
      color: var(--forest);
      letter-spacing: -0.05em;
      margin-bottom: 12px;
    }

    .price-side p { color: var(--muted); line-height: 1.6; margin-bottom: 16px; }

    .included-list {
      display: grid;
      gap: 10px;
      margin: 18px 0;
      padding: 0;
      list-style: none;
    }

    .included-list li { display: flex; gap: 9px; color: var(--ink); align-items: flex-start; }
    .included-list li::before { content: "•"; color: var(--gold); font-weight: 900; font-size: 1.15rem; line-height: 1.1; }
    .price-side .button { width: 100%; }

    .ambient-instagram-section { padding: clamp(40px, 7vw, 84px) 0; }

    .ambient-wrap {
      position: relative;
      min-height: 560px;
      border-radius: 42px;
      overflow: hidden;
      background: linear-gradient(140deg, #244b3e 0%, #173c30 55%, #102a21 100%);
      color: #f7f0e2;
      box-shadow: 0 30px 70px rgba(16, 42, 33, 0.22);
      border: 1px solid rgba(244,231,199,0.12);
      padding: clamp(28px, 5vw, 58px);
    }

    .ambient-copy { position: relative; z-index: 3; max-width: 560px; }
    .ambient-copy h2 { font-size: clamp(2.4rem, 6vw, 5.2rem); line-height: 0.94; color: #f7f0e2; margin-bottom: 18px; }
    .ambient-copy p { color: rgba(247,240,226,0.82); font-size: 1.06rem; max-width: 48ch; margin-bottom: 22px; }
    .ambient-actions { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }

    .hn-live-instagram-follow {
      display: inline-flex;
      justify-content: center;
      align-items: center;
      min-height: 56px;
      padding: 0 30px;
      border-radius: 999px;
      background: #f4e7c7;
      color: #173c30;
      text-decoration: none;
      font-size: 1.04rem;
      font-weight: 900;
      letter-spacing: 0.02em;
      white-space: nowrap;
      box-shadow: 0 16px 34px rgba(0, 0, 0, 0.18);
      transition: transform 0.22s ease, box-shadow 0.22s ease;
    }

    .hn-live-instagram-follow:hover { transform: translateY(-2px); box-shadow: 0 20px 42px rgba(0, 0, 0, 0.22); }

    .hn-live-instagram-avatar {
      width: 58px;
      height: 58px;
      border-radius: 999px;
      object-fit: cover;
      border: 2px solid rgba(244,231,199,0.55);
      background: #f8f3e8;
      box-shadow: 0 12px 26px rgba(0,0,0,0.18);
    }

    .ambient-posts { position: absolute; inset: 0; z-index: 2; pointer-events: none; }

    .ambient-post {
      position: absolute;
      width: clamp(130px, 16vw, 230px);
      pointer-events: auto;
      color: var(--forest);
      transition: transform 0.25s ease;
    }

    .ambient-post:hover { transform: translateY(-5px) rotate(var(--rotate, 0deg)); }
    .ambient-post img, .ambient-post .vibe-placeholder { aspect-ratio: 1 / 1; }
    .ambient-post.p1 { right: 8%; top: 8%; --rotate: 7deg; --float-delay: -2s; }
    .ambient-post.p2 { right: 30%; bottom: 8%; --rotate: -6deg; --float-delay: -4s; }
    .ambient-post.p3 { right: 4%; bottom: 16%; --rotate: 3deg; --float-delay: -6s; }
    .ambient-post.p4 { left: 48%; top: 26%; --rotate: -2deg; --float-delay: -1s; }
    .instagram-error-note { margin-top: 18px; color: rgba(247,240,226,0.68); font-size: 0.92rem; }

    .faq-strip {
      display: grid;
      grid-template-columns: 0.85fr 1.15fr;
      gap: clamp(20px, 4vw, 42px);
      align-items: stretch;
      padding: clamp(24px, 4vw, 42px);
      border-radius: 36px;
      background: radial-gradient(circle at top right, rgba(184, 139, 47, 0.13), transparent 34%), rgba(255, 252, 246, 0.66);
      overflow: hidden;
    }

    .faq-copy h2 { font-size: clamp(2rem, 5vw, 4.15rem); line-height: 0.96; color: var(--forest); max-width: 540px; }
    .faq-copy p { margin-top: 16px; max-width: 520px; color: var(--muted); font-size: 1rem; line-height: 1.7; }

    .random-faq-box {
      display: block;
      background: linear-gradient(135deg, rgba(255,255,255,0.72), rgba(255,252,246,0.54)), radial-gradient(circle at top right, rgba(184,139,47,0.16), transparent 38%);
      border: 1px solid rgba(39, 69, 55, 0.13);
      border-radius: 24px;
      padding: clamp(22px, 4vw, 34px);
      box-shadow: 0 18px 48px rgba(31, 28, 20, 0.08);
      transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
      min-height: 230px;
    }

    .random-faq-box:hover { transform: translateY(-3px); box-shadow: 0 24px 64px rgba(31, 28, 20, 0.12); border-color: rgba(184, 139, 47, 0.3); }

