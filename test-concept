  <script>
    const HN_INSTAGRAM_API_URL = "https://hamsa-instagram-feed.hamsanomads.workers.dev/instagram-feed";
    const HN_INSTAGRAM_AVATAR_FALLBACK = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 120 120'%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0' y1='0' x2='1' y2='1'%3E%3Cstop stop-color='%23F4E7C7'/%3E%3Cstop offset='1' stop-color='%23E7D2A2'/%3E%3C/linearGradient%3E%3C/defs%3E%3Crect width='120' height='120' rx='60' fill='url(%23g)'/%3E%3Ctext x='60' y='70' text-anchor='middle' font-family='Arial, sans-serif' font-size='34' font-weight='700' fill='%23274537'%3EHN%3C/text%3E%3C/svg%3E";
    const HN_INSTAGRAM_AVATAR_CANDIDATES = ["logo/logo-hamsa-nomads.png", "Image/logo-hamsa-nomads.png", "Image/Logo-hamsa-nomads.png", "Image/hamsa-logo.png", "Image/logo.png", "Image/hamsa-instagram-profile.jpg"];

    function hnEscapeHTML(value) {
      return String(value || "").replaceAll("&", "&amp;").replaceAll("<", "&lt;").replaceAll(">", "&gt;").replaceAll('"', "&quot;").replaceAll("'", "&#039;");
    }

    function hnHandleInstagramAvatarError(img) {
      if (!img) return;
      const attempted = Number(img.dataset.avatarIndex || 0) + 1;
      img.dataset.avatarIndex = attempted;
      if (attempted < HN_INSTAGRAM_AVATAR_CANDIDATES.length) {
        img.src = HN_INSTAGRAM_AVATAR_CANDIDATES[attempted];
        return;
      }
      img.onerror = null;
      img.src = HN_INSTAGRAM_AVATAR_FALLBACK;
    }

    function hnCleanCaption(caption, maxLength) {
      const clean = String(caption || "").replace(/\s+/g, " ").trim();
      if (!clean) return "Hamsa Nomads";
      return clean.length > maxLength ? clean.slice(0, maxLength).trim() + "..." : clean;
    }

    function hnShuffle(items) { return [...items].sort(() => Math.random() - 0.5); }
    function hnPostImage(post) { return post?.image || post?.thumbnail_url || post?.media_url || "Image/hero.jpg"; }

    function hnRenderAmbientPost(element, post) {
      if (!element || !post) return;
      const image = hnPostImage(post);
      const caption = hnCleanCaption(post.caption, 46);
      const url = post.url || post.permalink || "https://www.instagram.com/hamsanomads/";
      element.href = url;
      element.innerHTML = `
        <img src="${hnEscapeHTML(image)}" alt="${hnEscapeHTML(caption)}" loading="lazy" onerror="this.onerror=null; this.src='Image/hero.jpg';" />
        <span>${hnEscapeHTML(caption)}</span>
      `;
    }

    function hnRenderInstagramMoments(data) {
      const posts = Array.isArray(data.posts) ? hnShuffle(data.posts) : [];
      document.querySelectorAll(".hn-live-instagram-avatar").forEach((avatar) => {
        avatar.dataset.avatarIndex = "-1";
        avatar.src = data.profilePicture || HN_INSTAGRAM_AVATAR_CANDIDATES[0] || HN_INSTAGRAM_AVATAR_FALLBACK;
      });
      document.querySelectorAll(".hn-live-instagram-follow").forEach((link) => {
        link.href = data.profileUrl || "https://www.instagram.com/hamsanomads/";
      });
      Array.from(document.querySelectorAll(".hn-vibe-post")).forEach((element, index) => { if (posts[index]) hnRenderAmbientPost(element, posts[index]); });
      const marginPost = document.querySelector(".hn-margin-post");
      if (marginPost && posts[3]) hnRenderAmbientPost(marginPost, posts[3]);
      Array.from(document.querySelectorAll(".hn-ambient-post")).forEach((element, index) => {
        if (posts[index + 4]) hnRenderAmbientPost(element, posts[index + 4]);
        else if (posts[index]) hnRenderAmbientPost(element, posts[index]);
      });
    }

    async function hnLoadInstagramFeed() {
      const note = document.getElementById("hnInstagramNote");
      try {
        const response = await fetch(HN_INSTAGRAM_API_URL, { cache: "no-store" });
        if (!response.ok) throw new Error("Instagram feed request failed.");
        const data = await response.json();
        hnRenderInstagramMoments(data);
        if (note) note.textContent = "";
      } catch (error) {
        if (note) note.textContent = "Instagram moments are not available right now, but the page still works.";
        document.querySelectorAll(".hn-live-instagram-avatar").forEach((avatar) => {
          avatar.dataset.avatarIndex = "-1";
          avatar.src = HN_INSTAGRAM_AVATAR_CANDIDATES[0] || HN_INSTAGRAM_AVATAR_FALLBACK;
        });
      }
    }

    function hnInitReveals() {
      const revealItems = document.querySelectorAll("[data-reveal]");
      if (!("IntersectionObserver" in window)) {
        revealItems.forEach((item) => item.classList.add("is-visible"));
        return;
      }
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.14, rootMargin: "0px 0px -60px 0px" });
      revealItems.forEach((item) => observer.observe(item));
    }

    function hnInitCountdown() {
      const deadline = new Date("2026-05-03T23:59:59-04:00").getTime();
      const daysEl = document.getElementById("early-days");
      const hoursEl = document.getElementById("early-hours");
      const minutesEl = document.getElementById("early-minutes");
      const secondsEl = document.getElementById("early-seconds");
      const countdownWrap = document.getElementById("earlyBirdCountdown");
      if (!daysEl || !hoursEl || !minutesEl || !secondsEl) return;
      function pad(value) { return String(value).padStart(2, "0"); }
      function updateCountdown() {
        const distance = deadline - new Date().getTime();
        if (distance <= 0) {
          daysEl.textContent = hoursEl.textContent = minutesEl.textContent = secondsEl.textContent = "00";
          if (countdownWrap) {
            const header = countdownWrap.querySelector(".countdown-header");
            const note = countdownWrap.querySelector(".countdown-note");
            if (header) header.innerHTML = "<span>Early bird pricing</span><strong>Has ended</strong>";
            if (note) note.textContent = "Applications are still open for remaining spots.";
          }
          clearInterval(timer);
          return;
        }
        daysEl.textContent = pad(Math.floor(distance / (1000 * 60 * 60 * 24)));
        hoursEl.textContent = pad(Math.floor((distance / (1000 * 60 * 60)) % 24));
        minutesEl.textContent = pad(Math.floor((distance / (1000 * 60)) % 60));
        secondsEl.textContent = pad(Math.floor((distance / 1000) % 60));
      }
      updateCountdown();
      const timer = setInterval(updateCountdown, 1000);
    }

    async function loadRandomFaqFromPage() {
      const questionEl = document.getElementById("randomFaqQuestion");
      const answerEl = document.getElementById("randomFaqAnswer");
      const boxEl = document.getElementById("randomFaqBox");
      if (!questionEl || !answerEl || !boxEl) return;
      const fallbackFaqs = [
        { question: "Is this a hotel program?", answer: "No. Hamsa Nomads is a small, curated retreat in a private home, with shared meals, programming, and a more personal atmosphere." },
        { question: "Are public spaces Shabbos and Yom Tov observant?", answer: "Yes. Public spaces are designed around Shabbos and Chag observance so guests can feel comfortable joining the shared rhythm." },
        { question: "Why is there an application?", answer: "Because the retreat is small. We review applications so the group feels comfortable, balanced, and intentional." }
      ];
      try {
        const response = await fetch("faq.html", { cache: "no-store" });
        if (!response.ok) throw new Error("FAQ page could not be loaded.");
        const html = await response.text();
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, "text/html");
        const faqItems = Array.from(doc.querySelectorAll(".faq-item"));
        const faqs = faqItems.map((item) => {
          const question = item.querySelector(".faq-question span:first-child")?.textContent?.trim();
          const answer = item.querySelector(".faq-answer-inner")?.textContent?.trim();
          return { question, answer };
        }).filter((faq) => faq.question && faq.answer);
        if (!faqs.length) throw new Error("No FAQ items found.");
        const randomFaq = faqs[Math.floor(Math.random() * faqs.length)];
        questionEl.textContent = randomFaq.question;
        answerEl.textContent = randomFaq.answer.length > 230 ? randomFaq.answer.slice(0, 230).trim() + "..." : randomFaq.answer;
        boxEl.href = "faq.html";
      } catch (error) {
        const randomFallback = fallbackFaqs[Math.floor(Math.random() * fallbackFaqs.length)];
        questionEl.textContent = randomFallback.question;
        answerEl.textContent = randomFallback.answer;
        boxEl.href = "faq.html";
      }
    }

    function hnInitTrips() {
      const GOOGLE_SCRIPT_URL = "https://script.google.com/macros/s/AKfycbwk3snIWX2JsBWfteS9Id3he28StXSSO795Uv9r-FDtajbcn_KMWh1EZg04EiaxoNWd/exec";
      const TRIPS_PAGE_URL = "trips-page/trips.html";
      const slider = document.getElementById("hnTripSlider");
      const prevBtn = document.getElementById("hnTripsPrev");
      const nextBtn = document.getElementById("hnTripsNext");
      const dotsWrap = document.getElementById("hnTripDots");
      const popup = document.getElementById("tripPopup");
      const popupClose = document.getElementById("popupClose");
      const popupTitle = document.getElementById("popupTitle");
      const popupSubtitle = document.getElementById("popupSubtitle");
      const tripInterestInput = document.getElementById("tripInterest");
      const tripForm = document.getElementById("tripForm");
      const popupMessage = document.getElementById("popupMessage");
      if (!slider || !dotsWrap) return;

      const tripCopy = { "General Trips Interest": { title: "Hamsa Nomads trips", subtitle: "Leave your info and we’ll send updates as future trips open." } };
      const fallbackTrips = [{ title: "Future Hamsa Nomads trips", meta: "More dates soon", text: "City weekends, playful escapes, holiday retreats, and small Jewish travel experiences are already forming.", badge: "Upcoming", status: "Interest list open", ctaText: "Join interest list", bullets: ["Small groups", "Jewish travel rhythm", "Warm and curated"], image: "Image/hero.jpg", tripInterest: "General Trips Interest" }];
      function cleanText(text) { return (text || "").replace(/\s+/g, " ").trim(); }
      function getBackgroundImageUrl(styleValue, baseUrl) { const match = String(styleValue || "").match(/url\((['"]?)(.*?)\1\)/i); if (!match || !match[2]) return ""; return new URL(match[2], baseUrl).href; }
      function getTripNameFromOnclick(onclickValue) { const match = String(onclickValue || "").match(/openTripPopup\(['"](.+?)['"]\)/); return match ? match[1] : ""; }
      function extractTripCardsFromTripsPage(html) {
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, "text/html");
        const baseUrl = new URL(TRIPS_PAGE_URL, window.location.href);
        const cards = Array.from(doc.querySelectorAll(".bento-grid .bento-card:not(.bento-cta-card)"));
        return cards.map((card) => {
          const imageEl = card.querySelector(".bento-image");
          const button = card.querySelector(".trip-cta");
          const title = cleanText(card.querySelector(".bento-title")?.textContent);
          const meta = cleanText(card.querySelector(".bento-meta")?.textContent);
          const text = cleanText(card.querySelector(".bento-text")?.textContent);
          const badge = cleanText(imageEl?.querySelector(".bento-badge")?.textContent) || "Upcoming trip";
          const status = cleanText(card.querySelector(".bento-status")?.textContent);
          const ctaText = cleanText(button?.textContent) || "Join the interest list";
          const bullets = Array.from(card.querySelectorAll(".bento-list li")).map((li) => cleanText(li.textContent)).filter(Boolean);
          const imageStyle = imageEl?.getAttribute("style") || imageEl?.style?.backgroundImage || "";
          const image = getBackgroundImageUrl(imageStyle, baseUrl);
          const tripInterest = getTripNameFromOnclick(button?.getAttribute("onclick")) || title;
          tripCopy[tripInterest] = { title, subtitle: text || "Leave your info and we’ll send details as this trip comes together." };
          return { title, meta, text, badge, status, ctaText, bullets, image, tripInterest };
        }).filter((trip) => trip.title);
      }
      function renderTrips(trips) {
        if (!trips.length) trips = fallbackTrips;
        slider.innerHTML = trips.map((trip, index) => {
          const bullets = (trip.bullets || []).slice(0, 4).map((bullet) => `<li>${hnEscapeHTML(bullet)}</li>`).join("");
          const imageStyle = trip.image ? `style="--trip-image: url('${hnEscapeHTML(trip.image)}');"` : "";
          return `
            <article class="hn-trip-slide">
              <div class="hn-trip-card">
                <div class="hn-trip-image" ${imageStyle}>
                  <div class="hn-trip-badge">${hnEscapeHTML(trip.badge || "Upcoming")}</div>
                  ${trip.meta ? `<div class="hn-image-note">${hnEscapeHTML(trip.meta)}</div>` : ""}
                </div>
                <div class="hn-trip-body">
                  ${trip.meta ? `<div class="hn-trip-meta">${hnEscapeHTML(trip.meta)}</div>` : ""}
                  <h3 class="hn-trip-name">${hnEscapeHTML(trip.title)}</h3>
                  <p class="hn-trip-copy">${hnEscapeHTML(trip.text || "")}</p>
                  ${bullets ? `<ul class="hn-trip-bullets">${bullets}</ul>` : ""}
                  <div class="hn-trip-footer">
                    <span class="hn-trip-status"><span class="hn-trip-status-dot"></span>${hnEscapeHTML(trip.status || "Interest list open")}</span>
                    <button type="button" class="hn-trip-cta" data-trip-interest="${hnEscapeHTML(trip.tripInterest || trip.title)}">${hnEscapeHTML(trip.ctaText || "Join interest list")}</button>
                  </div>
                </div>
              </div>
            </article>`;
        }).join("");
        dotsWrap.innerHTML = trips.map((_, index) => `<button type="button" class="hn-slider-dot ${index === 0 ? "is-active" : ""}" data-slide-index="${index}" aria-label="Go to trip ${index + 1}"></button>`).join("");
        updateSliderButtons();
        slider.querySelectorAll(".hn-trip-cta").forEach((button) => button.addEventListener("click", () => openTripPopup(button.dataset.tripInterest || "General Trips Interest")));
        dotsWrap.querySelectorAll(".hn-slider-dot").forEach((dot) => dot.addEventListener("click", () => {
          const slide = slider.children[Number(dot.dataset.slideIndex || 0)];
          if (slide) slider.scrollTo({ left: slide.offsetLeft - slider.offsetLeft, behavior: "smooth" });
        }));
      }
      function updateSliderButtons() {
        if (!slider || !prevBtn || !nextBtn) return;
        const maxScroll = slider.scrollWidth - slider.clientWidth;
        prevBtn.disabled = slider.scrollLeft <= 4;
        nextBtn.disabled = slider.scrollLeft >= maxScroll - 4;
        const slides = Array.from(slider.children);
        let activeIndex = 0;
        let smallestDistance = Infinity;
        slides.forEach((slide, index) => {
          const distance = Math.abs(slider.scrollLeft - (slide.offsetLeft - slider.offsetLeft));
          if (distance < smallestDistance) { smallestDistance = distance; activeIndex = index; }
        });
        dotsWrap.querySelectorAll(".hn-slider-dot").forEach((dot, index) => dot.classList.toggle("is-active", index === activeIndex));
      }
      function openTripPopup(tripInterest) {
        if (!popup || !tripInterestInput || !popupTitle || !popupSubtitle) return;
        const copy = tripCopy[tripInterest] || tripCopy["General Trips Interest"];
        tripInterestInput.value = tripInterest;
        popupTitle.textContent = copy.title || "Upcoming Trip";
        popupSubtitle.textContent = copy.subtitle || "Leave your info and we’ll send details as this trip comes together.";
        popupMessage.textContent = "";
        popupMessage.classList.remove("error");
        popup.classList.add("is-open");
        document.body.style.overflow = "hidden";
      }
      function closeTripPopup() { if (!popup) return; popup.classList.remove("is-open"); document.body.style.overflow = ""; }
      function setupTripInteractions() {
        if (prevBtn) prevBtn.addEventListener("click", () => slider.scrollBy({ left: -slider.clientWidth * 0.85, behavior: "smooth" }));
        if (nextBtn) nextBtn.addEventListener("click", () => slider.scrollBy({ left: slider.clientWidth * 0.85, behavior: "smooth" }));
        slider.addEventListener("scroll", updateSliderButtons, { passive: true });
        window.addEventListener("resize", updateSliderButtons);
        if (popupClose) popupClose.addEventListener("click", closeTripPopup);
        if (popup) popup.addEventListener("click", (event) => { if (event.target === popup) closeTripPopup(); });
        document.addEventListener("keydown", (event) => { if (event.key === "Escape" && popup && popup.classList.contains("is-open")) closeTripPopup(); });
        if (tripForm) {
          tripForm.addEventListener("submit", function (event) {
            event.preventDefault();
            if (!GOOGLE_SCRIPT_URL || GOOGLE_SCRIPT_URL.includes("PASTE_YOUR_GOOGLE_SCRIPT")) {
              popupMessage.textContent = "Add your Google Script link in the code first.";
              popupMessage.classList.add("error");
              return;
            }
            const submitButton = tripForm.querySelector(".popup-submit");
            const formData = new FormData(tripForm);
            formData.append("timestamp", new Date().toISOString());
            formData.append("sourcePage", "index.html");
            submitButton.disabled = true;
            submitButton.textContent = "Submitting...";
            popupMessage.textContent = "";
            popupMessage.classList.remove("error");
            fetch(GOOGLE_SCRIPT_URL, { method: "POST", body: formData })
              .then(() => {
                popupMessage.textContent = "You’re on the list. We’ll send details soon.";
                tripForm.reset();
                setTimeout(() => { closeTripPopup(); submitButton.disabled = false; submitButton.textContent = "Join interest list"; }, 1300);
              })
              .catch(() => {
                popupMessage.textContent = "Something went wrong. Please try again.";
                popupMessage.classList.add("error");
                submitButton.disabled = false;
                submitButton.textContent = "Join interest list";
              });
          });
        }
      }
      async function loadTripsFromTripsPage() {
        try {
          const response = await fetch(TRIPS_PAGE_URL, { cache: "no-store" });
          if (!response.ok) throw new Error("Trips page could not be loaded.");
          const html = await response.text();
          const trips = extractTripCardsFromTripsPage(html);
          renderTrips(trips.length ? trips : fallbackTrips);
        } catch (error) {
          renderTrips(fallbackTrips);
        }
      }
      setupTripInteractions();
      loadTripsFromTripsPage();
    }

    function hnInitShare() {
      const shareBtn = document.getElementById("shareBtn");
      const shareOptions = document.getElementById("shareOptions");
      const copyLinkBtn = document.getElementById("copyLinkBtn");
      const pageUrl = encodeURIComponent(window.location.href);
      const pageTitle = encodeURIComponent(document.title || "Hamsa Nomads");
      const whatsappShare = document.getElementById("whatsappShare");
      const facebookShare = document.getElementById("facebookShare");
      const emailShare = document.getElementById("emailShare");
      if (whatsappShare) whatsappShare.href = `https://wa.me/?text=${pageTitle}%20${pageUrl}`;
      if (facebookShare) facebookShare.href = `https://www.facebook.com/sharer/sharer.php?u=${pageUrl}`;
      if (emailShare) emailShare.href = `mailto:?subject=${pageTitle}&body=${pageUrl}`;
      if (shareBtn && shareOptions) {
        shareBtn.addEventListener("click", () => shareOptions.classList.toggle("open"));
        document.addEventListener("click", (event) => { if (!event.target.closest(".floating-share")) shareOptions.classList.remove("open"); });
      }
      if (copyLinkBtn) {
        copyLinkBtn.addEventListener("click", async () => {
          try {
            await navigator.clipboard.writeText(window.location.href);
            copyLinkBtn.textContent = "Copied!";
            setTimeout(() => { copyLinkBtn.textContent = "Copy link"; }, 1600);
          } catch (err) {
            alert("Copy failed. Please copy the URL manually.");
          }
        });
      }
    }

    document.addEventListener("DOMContentLoaded", function () {
      hnInitReveals();
      hnInitCountdown();
      hnLoadInstagramFeed();
      loadRandomFaqFromPage();
      hnInitTrips();
      hnInitShare();
    });
  </script>
</body>
</html>
