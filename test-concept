    .popup-content { position: relative; z-index: 2; }
    .popup-kicker { font-size: 0.78rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--forest); font-weight: 900; margin-bottom: 10px; }
    .popup-title { margin: 0; font-size: clamp(1.8rem, 5vw, 2.35rem); line-height: 1.05; color: var(--ink); }
